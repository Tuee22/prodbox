# Generated by `prodbox docs generate`.
_prodbox()
{
  local cur key words
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  if (( COMP_CWORD <= 1 )); then
    words="aws charts check-code commands config dns docs gateway help host k8s lint pulumi rke2 test tla-check workload"
  else
    key="${COMP_WORDS[@]:1:COMP_CWORD-1}"
    case "$key" in
      "aws")
        words="policy setup teardown check-quotas request-quotas"
        ;;
      "charts")
        words="list status deploy delete"
        ;;
      "config")
        words="setup show validate"
        ;;
      "dns")
        words="check"
        ;;
      "docs")
        words="check generate"
        ;;
      "gateway")
        words="start status config-gen"
        ;;
      "host")
        words="ensure-tools check-ports info firewall public-edge"
        ;;
      "k8s")
        words="health wait logs"
        ;;
      "lint")
        words="all files docs haskell chart"
        ;;
      "pulumi")
        words="eks-resources eks-destroy test-resources test-destroy"
        ;;
      "rke2")
        words="status start stop restart reconcile install delete logs"
        ;;
      "test")
        words="all lint unit integration"
        ;;
      "test integration")
        words="all cli aws-iam dns-aws aws-eks env gateway-daemon gateway-pods gateway-partition ha-rke2-aws lifecycle pulumi charts-storage charts-platform charts-vscode charts-api charts-websocket admin-routes public-dns"
        ;;
      "workload")
        words="start"
        ;;
      *) words="" ;;
    esac
  fi
  COMPREPLY=( $(compgen -W "$words" -- "$cur") )
}
complete -F _prodbox prodbox
