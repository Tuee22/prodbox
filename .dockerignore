.DS_Store
Thumbs.db

# Secrets (never commit)
*.pem
*.key
credentials.json
secrets.yaml

# Poetry
# Lock file is not version controlled - each developer generates locally
# This ensures reproducible builds while allowing flexibility across environments
poetry.lock

