    type:             exitcode-stdio-1.0
    main-is:          Main.hs
    hs-source-dirs:   test/pulumi test/support
    other-modules:    TestSupport
    default-language: GHC2021
    ghc-options:      -Wall
    build-depends:
        base ^>=4.22.0.0 || ^>=4.18.2.1,
        bytestring ^>=0.11.5.3,
        containers ^>=0.6.7,
        directory ^>=1.3.8.5,
        filepath ^>=1.4.2.2,
        prodbox,
        tasty ^>=1.5,
        tasty-golden ^>=2.3.5,
