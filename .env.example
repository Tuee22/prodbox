# AWS Credentials (Required)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Route 53 (Required)
ROUTE53_ZONE_ID=

# ACME / Let's Encrypt (Required)
ACME_EMAIL=

# Domain Configuration
DEMO_FQDN=demo.example.com
DEMO_TTL=60

# MetalLB / Ingress Configuration
METALLB_POOL=192.168.1.240-192.168.1.250
INGRESS_LB_IP=192.168.1.240

# Kubernetes
KUBECONFIG=~/.kube/config

# ACME Server (default: production Let's Encrypt)
# Use staging for testing: https://acme-staging-v02.api.letsencrypt.org/directory
ACME_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Pulumi
PULUMI_STACK=home
